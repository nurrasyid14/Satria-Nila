# SATRIA - Environment Variables Example
# Salin file ini menjadi .env dan isi nilainya.

# --- SUPABASE CONFIG (Data-Service) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key

# --- SERVICE MAPPING (API-Service Gateway) ---
# Gunakan 127.0.0.1 untuk local run, atau nama service jika menggunakan Docker
ML_SERVICE_URL=http://127.0.0.1:8001
DATA_SERVICE_URL=http://127.0.0.1:8002
